# Keep our de-Lovabled versions of these files on merges from a Lovable upstream.
# Requires the local "ours" merge driver to be registered once:
#   git config merge.ours.driver true
# (scripts/setup-merge-drivers.sh does this for you)
# Lovable's scratch plan file was removed from this fork; upstream keeps editing
# it, which conflicts on every merge. Keep our version (deleted).
.lovable/** merge=ours
vite.config.ts merge=ours
bunfig.toml merge=ours
.env.example merge=ours
.gitignore merge=ours
